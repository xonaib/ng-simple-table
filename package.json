{
  "name": "demo-table",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open --port 4200",
    "build": "npm run build:lib && ng build",
    "build:lib": "ng build ngx-mat-simple-table",
    "build:lib:watch": "ng build ngx-mat-simple-table --watch",
